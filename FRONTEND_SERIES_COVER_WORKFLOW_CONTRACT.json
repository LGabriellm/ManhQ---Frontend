{
  "version": "1.0.0",
  "timestamp": "2026-03-19",
  "title": "Series Cover Management Contract",
  "status": "production-ready",
  "description": "Contrato para o frontend implementar troca de capa da série por (1) capítulo existente ou (2) upload de imagem única do computador.",

  "goals": [
    "Permitir escolher uma capa a partir de um capítulo da própria série",
    "Permitir upload de uma imagem única como capa personalizada",
    "Atualizar imediatamente a capa exibida em /series/:id/cover"
  ],

  "feature_entrypoint": {
    "screen": "Detalhe da Série",
    "ui_action": "Botão 'Alterar capa'",
    "modal_options": [
      "Escolher capa de um capítulo",
      "Enviar imagem do computador"
    ]
  },

  "backend_endpoints": {
    "get_series_details": {
      "method": "GET",
      "path": "/series/:id",
      "purpose": "Buscar dados da série e lista de capítulos para o usuário escolher a origem da capa",
      "response_fields_used_by_frontend": {
        "id": "string",
        "title": "string",
        "coverUrl": "string | null",
        "medias": [
          {
            "id": "string",
            "title": "string",
            "number": "number"
          }
        ]
      }
    },

    "get_current_cover": {
      "method": "GET",
      "path": "/series/:id/cover",
      "purpose": "Renderizar capa atual (sempre usar este endpoint para preview final)",
      "response": {
        "content_type": "image/jpeg",
        "cache_control": "public, max-age=86400, immutable"
      }
    },

    "set_cover_from_chapter": {
      "method": "POST",
      "path": "/series/:id/cover/from-chapter",
      "auth": "editor_or_admin",
      "content_type": "application/json",
      "purpose": "Define a capa da série usando a primeira página de um capítulo da própria série",
      "request_body": {
        "mediaId": "string (obrigatório)"
      },
      "response_200": {
        "success": true,
        "seriesId": "string",
        "mediaId": "string",
        "coverUrl": "/series/:id/cover",
        "source": "chapter"
      },
      "errors": {
        "400": "mediaId é obrigatório",
        "404": "Série não encontrada ou capítulo não pertence à série",
        "500": "Erro ao gerar capa"
      },
      "frontend_note": "Após sucesso, recarregar preview com cache-buster: /series/:id/cover?t=<timestamp>"
    },

    "set_cover_from_upload": {
      "method": "POST",
      "path": "/series/:id/cover/upload",
      "auth": "editor_or_admin",
      "content_type": "multipart/form-data",
      "purpose": "Define capa da série por upload de uma única imagem do computador",
      "request_form_data": {
        "cover": "File (obrigatório)"
      },
      "accepted_image_formats": ["jpg", "jpeg", "png", "webp", "gif", "bmp"],
      "server_processing": {
        "auto_rotate": true,
        "max_width": 400,
        "output_format": "jpeg",
        "quality": 85
      },
      "response_200": {
        "success": true,
        "seriesId": "string",
        "coverUrl": "/series/:id/cover",
        "source": "upload"
      },
      "errors": {
        "400": "Arquivo de capa não enviado ou formato inválido",
        "404": "Série não encontrada",
        "500": "Erro ao processar upload"
      },
      "frontend_note": "Sempre enviar o arquivo no campo 'cover'"
    }
  },

  "frontend_state_machine": {
    "states": [
      "IDLE",
      "OPEN_MODAL",
      "SELECT_SOURCE",
      "CHAPTER_PICKER",
      "UPLOAD_PICKER",
      "SUBMITTING",
      "SUCCESS",
      "ERROR"
    ],
    "transitions": [
      {
        "from": "IDLE",
        "event": "CLICK_CHANGE_COVER",
        "to": "OPEN_MODAL"
      },
      {
        "from": "OPEN_MODAL",
        "event": "CHOOSE_CHAPTER_SOURCE",
        "to": "CHAPTER_PICKER"
      },
      {
        "from": "OPEN_MODAL",
        "event": "CHOOSE_UPLOAD_SOURCE",
        "to": "UPLOAD_PICKER"
      },
      {
        "from": "CHAPTER_PICKER",
        "event": "CONFIRM_MEDIA_ID",
        "to": "SUBMITTING"
      },
      {
        "from": "UPLOAD_PICKER",
        "event": "CONFIRM_FILE",
        "to": "SUBMITTING"
      },
      {
        "from": "SUBMITTING",
        "event": "REQUEST_SUCCESS",
        "to": "SUCCESS"
      },
      {
        "from": "SUBMITTING",
        "event": "REQUEST_ERROR",
        "to": "ERROR"
      }
    ]
  },

  "frontend_ux_requirements": {
    "chapter_mode": [
      "Listar capítulos com id, número e título",
      "Permitir seleção de 1 capítulo",
      "Mostrar aviso: 'a capa será a primeira página do capítulo selecionado'"
    ],
    "upload_mode": [
      "Aceitar somente arquivos de imagem",
      "Exibir preview local antes de confirmar",
      "Bloquear envio se arquivo não existir"
    ],
    "loading_feedback": [
      "Desabilitar botão de confirmar durante SUBMITTING",
      "Mostrar texto: 'Atualizando capa...'",
      "Em sucesso, fechar modal e atualizar thumbnail da série"
    ],
    "error_feedback": [
      "400: mostrar mensagem de validação",
      "404: mostrar 'Série/capítulo não encontrado'",
      "500: mostrar erro genérico e opção de tentar novamente"
    ]
  },

  "integration_examples": {
    "example_set_from_chapter": {
      "request": {
        "method": "POST",
        "url": "/series/series_123/cover/from-chapter",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer <token>"
        },
        "body": {
          "mediaId": "media_987"
        }
      },
      "response": {
        "success": true,
        "seriesId": "series_123",
        "mediaId": "media_987",
        "coverUrl": "/series/series_123/cover",
        "source": "chapter"
      }
    },

    "example_set_from_upload": {
      "request": {
        "method": "POST",
        "url": "/series/series_123/cover/upload",
        "headers": {
          "Authorization": "Bearer <token>"
        },
        "formData": {
          "cover": "<file.jpg>"
        }
      },
      "response": {
        "success": true,
        "seriesId": "series_123",
        "coverUrl": "/series/series_123/cover",
        "source": "upload"
      }
    }
  },

  "implementation_checklist": [
    "Criar modal 'Alterar capa' na tela de detalhe da série",
    "Consumir GET /series/:id para montar seletor de capítulos",
    "Implementar ação POST /series/:id/cover/from-chapter com mediaId",
    "Implementar ação POST /series/:id/cover/upload com form-data (campo cover)",
    "Após sucesso, invalidar cache da imagem e recarregar /series/:id/cover?t=Date.now()",
    "Exibir mensagens de erro por status code"
  ],

  "security_and_permissions": {
    "required_role": "EDITOR ou ADMIN",
    "auth_required": true,
    "notes": [
      "Endpoints de alteração de capa são protegidos",
      "Usuário comum sem permissão recebe erro de autorização"
    ]
  }
}
