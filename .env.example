# Docker Compose Project Configuration
COMPOSE_PROJECT_NAME=manhq

# URL do backend (obrigatório)
# Usado pelo Next.js para proxy de /api/*
API_URL=https://api.manhq.com.br

# URL pública da API (usada no cliente/navegador)
NEXT_PUBLIC_API_URL=https://api.manhq.com.br

# Traefik Configuration (Hostinger Docker Manager)
# Domínio onde o frontend será exposto através do Traefik
# Exemplo: app.seudominio.com ou seudominio.com
TRAEFIK_HOST=app.seudominio.com
